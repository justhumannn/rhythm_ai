NGROK_AUTHTOKEN=your-ngrok-authtoken
AI_SERVICE_TOKEN=change-this-long-random-token

# rhythm_model_server 저장소가 rhythm 폴더의 형제 디렉터리에 있으면 그대로 둡니다.
RHYTHM_MODEL_SERVER_DIR=../rhythm_model_server

RHYTHM_MAX_CONCURRENT_JOBS=1
AI_MAX_CONCURRENT_JOBS=1
AI_SERVICE_TIMEOUT_SECONDS=600
AI_MAX_UPLOAD_BYTES=524288000
YOUTUBE_MAX_DURATION_SECONDS=600
YOUTUBE_MAX_FILESIZE_BYTES=524288000

# YouTube 쿠키가 필요할 때만 사용합니다.
# YOUTUBE_COOKIES_HOST_FILE=./youtube-cookies.txt
# YOUTUBE_COOKIES_FILE=/run/secrets/youtube-cookies.txt
# YOUTUBE_USER_AGENT=
