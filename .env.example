RHYTHM_ENV=local
DATABASE_URL=sqlite:///data/rhythm_web.sqlite
SUPABASE_DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres?sslmode=require
RHYTHM_STORAGE_DIR=/var/data
RHYTHM_CHECKPOINT=checkpoints/djmax_4b_aligned.pt
RHYTHM_MAX_CONCURRENT_JOBS=1
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=2
DATABASE_POOL_RECYCLE=300
YOUTUBE_MAX_DURATION_SECONDS=600
YOUTUBE_MAX_FILESIZE_BYTES=524288000
